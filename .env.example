# Printavo API credentials — get from Printavo > My Account > API
PRINTAVO_EMAIL=you@yourbusiness.com
PRINTAVO_API_TOKEN=your_printavo_api_token_here

# MCP server authentication
# Protects POST /mcp. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=generate_a_strong_random_secret_here

# Server port (optional, defaults to 3000)
PORT=3000

# CORS allowed origins (comma-separated; default: *)
# Examples:
#   ALLOWED_ORIGINS=https://www.perplexity.ai,https://claude.ai
#   ALLOWED_ORIGINS=*
ALLOWED_ORIGINS=*

# Log level (trace, debug, info, warn, error, fatal). Default: info
LOG_LEVEL=info

# NODE_ENV=production switches Pino from pretty to JSON logs
NODE_ENV=development
