# =====================================================================
# REQUIRED
# =====================================================================

# Printavo API credentials — get from Printavo > My Account > API
PRINTAVO_EMAIL=you@yourbusiness.com
PRINTAVO_API_TOKEN=your_printavo_api_token_here

# OAuth issuer URL — the public base URL of this server (no trailing slash).
# Used in JWT iss/aud claims and in .well-known metadata.
OAUTH_ISSUER_URL=https://your-app.up.railway.app

# OAuth JWT signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
OAUTH_JWT_SECRET=generate_a_strong_random_secret

# Authorized users (JSON array).
# Each entry: { "email": "...", "password_hash": "<bcrypt hash>" }
# Generate a bcrypt hash with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
OAUTH_USERS=[{"email":"you@yourbusiness.com","password_hash":"$2b$12$..."}]

# =====================================================================
# OPTIONAL
# =====================================================================

# Debug/curl fallback: static Bearer key accepted on /mcp alongside OAuth JWTs.
# Leave unset in production to require OAuth for every request.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MCP_API_KEY=

# Server port (defaults to 3000; Railway injects its own).
PORT=3000

# CORS allowed origins (comma-separated; default: *)
#   ALLOWED_ORIGINS=https://claude.ai,https://claude.com
ALLOWED_ORIGINS=*

# Pino log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# NODE_ENV=production switches Pino from pretty to JSON logs
NODE_ENV=development
